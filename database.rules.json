{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",

        "profile": {
          ".write": "$uid === auth.uid",

          "phoneNumber": {
            // A friend may read ONLY this field. The check looks at the
            // profile owner's own friendUids index (which only the owner can
            // write), so a caller can't grant themselves access — the
            // friendship has to be one the owner actually recorded.
            ".read": "auth.uid === $uid || root.child('users').child($uid).child('friendUids').child(auth.uid).exists()"
          },

          "paymentHandles": {
            // A confirmed friend may read these (Venmo/PayPal/Cash App handles)
            // to build a payment-request link — same friend-scoped rule as
            // phoneNumber above. TABS never moves money; the handle just seeds a
            // deep link the friend opens in their payment app.
            ".read": "auth.uid === $uid || root.child('users').child($uid).child('friendUids').child(auth.uid).exists()"
          }
        },

        "peopleList":   { ".write": "$uid === auth.uid" },
        "history":      { ".write": "$uid === auth.uid" },
        "lastCleared":  { ".write": "$uid === auth.uid" },
        "spending":     { ".write": "$uid === auth.uid" },
        "settings":     { ".write": "$uid === auth.uid" },
        "notifications": {
          // Owner can read/manage everything (mark read, clear all, etc.).
          ".write": "$uid === auth.uid",
          "$notif_id": {
            // Other signed-in users may only CREATE a notification (friend
            // request/accept, reminder) — never overwrite or delete an
            // existing one — and must stamp it with their own uid so the
            // recipient can tell who sent it and the sender can't spoof.
            ".write": "auth != null && !data.exists() && newData.exists() && newData.child('fromUid').val() === auth.uid",
            ".validate": "!newData.exists() || (newData.hasChild('message') && newData.hasChild('timestamp') && newData.child('message').isString() && newData.child('message').val().length <= 500 && newData.child('timestamp').isNumber())"
          }
        },
        "autoReminders": { ".write": "$uid === auth.uid" },

        "pushTokens": {
          // Each user registers their own device push tokens here. The
          // sendReminderPush Cloud Function (admin SDK, bypasses rules) reads a
          // friend's tokens to deliver reminders; no client ever needs to read
          // someone else's tokens.
          ".write": "$uid === auth.uid"
        },

        "friendUids": {
          // UID-keyed mirror of friendsList, maintained by the owner only and
          // used purely to authorize friends to read the phone number above.
          ".write": "$uid === auth.uid",
          "$friend_uid": {
            ".validate": "newData.isBoolean()"
          }
        },

        "friendsList": {
          // Only the profile owner can manage their own friends list
          ".write": "$uid === auth.uid",
          "$pushed_id": {
            // friendCode/phoneNumber are intentionally NOT required: RTDB drops
            // null children, so a friend with no friendCode (or no phone) would
            // fail a hasChild() check and have the whole write denied.
            ".validate": "newData.hasChild('userId') && newData.hasChild('firstName') && newData.hasChild('lastName')"
          }
        },
        "sentRequests": {
           // The owner manages their own sent requests; additionally, the
           // request's RECIPIENT may DELETE (only) the entry addressed to
           // them, so rejecting/declining a request clears the sender's
           // "request sent" state too (this used to be denied, which broke
           // the whole reject flow client-side).
           ".write": "$uid === auth.uid",
           "$receiver_uid": {
             ".write": "auth.uid === $receiver_uid && !newData.exists()",
             ".validate": "!newData.exists() || (newData.hasChild('toUserId') && newData.hasChild('firstName') && newData.hasChild('lastName'))"
           }
        },
        "pendingRequests": {
          "$requester_uid": {
            ".write": "auth.uid === $requester_uid || auth.uid === $uid",
            ".validate": "!newData.exists() || (newData.hasChild('fromUserId') && newData.hasChild('firstName') && newData.hasChild('lastName') && newData.child('fromUserId').val() === $requester_uid)"
          }
        }
      }
    },
    "friendCodes": {
      // Reads are scoped to a single, exact code — you can look up the code a
      // friend gave you, but you can no longer download the whole node and
      // enumerate every user's name/uid/code.
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid)",
        ".validate": "!newData.exists() || (newData.hasChild('userId') && newData.child('userId').val() === auth.uid)"
      }
    }
  }
}
